{
  "system_description": "AegisIDE Router-First Dynamic System - Single Source of Truth",
  "version": "2.0.0",
  "last_updated": "2025-10-18T19:38:16+05:30",
  
  "operational_loop": {
    "description": "Core execution sequence for every session/request",
    "steps": [
      {
        "step": 1,
        "name": "Session Awareness",
        "action": "Display constitutional rules",
        "query": "@mcp:json-jq query '.session_awareness.content[]' from 'context-router.json'",
        "requirement": "FIRST action on new sessions"
      },
      {
        "step": 2,
        "name": "DeepThink", 
        "action": "Use @mcp:sequential-thinking (≥3 steps)",
        "query": "@mcp:json-jq query '.mcps.always_active[]' from 'context-router.json'",
        "requirement": "EVERY request"
      },
      {
        "step": 3,
        "name": "Query Router",
        "action": "Get dynamic paths and rules", 
        "query": "@mcp:json-jq query '.system_paths' from 'context-router.json'",
        "requirement": "NEVER use static paths"
      },
      {
        "step": 4,
        "name": "Execute",
        "action": "Use mandatory MCPs and CLI pipeline",
        "query": "@mcp:json-jq query '.mcps' from 'context-router.json'",
        "requirement": "Complete MCP trail required"
      },
      {
        "step": 5,
        "name": "Update Memory",
        "action": "Atomically update all 8 schemas",
        "query": "@mcp:json-jq query '.memory_bank.schemas[]' from 'context-router.json'",
        "requirement": "All 8 schemas or HALT"
      },
      {
        "step": 6,
        "name": "Auto-Continue",
        "action": "Process next task immediately",
        "query": "@mcp:json-jq query '.autonomy_rules' from 'context-router.json'",
        "requirement": "0-99% band, no permission"
      }
    ]
  },

  "system_paths": {
    "memory_bank": "{IDE}/.aegiside/memory-bank/",
    "schemas": "{IDE}/.aegiside/schemas/",
    "constitution": "{GLOBAL_MEMORY}/memories/",
    "workflows": "{IDE}/workflow/"
  },

  "ide_detection": {
    "description": "Multi-IDE and multi-platform path resolution system with platform-specific paths",
    "supported_ides": {
      "windsurf": {
        "folder": ".windsurf",
        "platform_paths": {
          "windows": "%USERPROFILE%\\.codeium\\windsurf-next",
          "macos": "~/Library/Application Support/Codeium/windsurf-next", 
          "linux": "~/.codeium/windsurf-next"
        },
        "config_location": "{GLOBAL_MEMORY}/mcp_config.json"
      },
      "cursor": {
        "folder": ".cursor",
        "platform_paths": {
          "windows": "%APPDATA%\\Cursor",
          "macos": "~/Library/Application Support/Cursor",
          "linux": "~/.config/Cursor"
        },
        "config_location": "{GLOBAL_MEMORY}/mcp_config.json"
      },
      "vscode": {
        "folder": ".vscode",
        "platform_paths": {
          "windows": "%APPDATA%\\Code\\User",
          "macos": "~/Library/Application Support/Code/User",
          "linux": "~/.config/Code/User"
        },
        "config_location": "{GLOBAL_MEMORY}/mcp_config.json"
      },
      "cline": {
        "folder": ".cline",
        "platform_paths": {
          "windows": "%APPDATA%\\Cline",
          "macos": "~/Library/Application Support/Cline",
          "linux": "~/.config/Cline"
        },
        "config_location": "{GLOBAL_MEMORY}/mcp_config.json"
      },
      "jetbrains": {
        "folder": ".idea",
        "platform_paths": {
          "windows": "%APPDATA%\\JetBrains",
          "macos": "~/Library/Application Support/JetBrains",
          "linux": "~/.config/JetBrains"
        },
        "config_location": "{GLOBAL_MEMORY}/mcp_config.json"
      },
      "zed": {
        "folder": ".zed",
        "platform_paths": {
          "windows": "%APPDATA%\\Zed",
          "macos": "~/Library/Application Support/Zed",
          "linux": "~/.config/Zed"
        },
        "config_location": "{GLOBAL_MEMORY}/mcp_config.json"
      }
    },
    "path_variables": {
      "{IDE}": "Current workspace root path (auto-detected)",
      "{GLOBAL_MEMORY}": "IDE-specific global memory path (auto-resolved)",
      "{PLATFORM}": "Platform-specific paths (windows/linux/macos)",
      "~": "User home directory (cross-platform)"
    },
    "platform_support": ["windows", "linux", "macos"],
    "auto_detection": "Query environment to determine current IDE and platform"
  },

