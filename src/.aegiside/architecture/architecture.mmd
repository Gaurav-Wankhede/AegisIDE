graph TB
    subgraph USER_FLOW["User Interaction Flow - End to End"]
        U1[User Message Input]
        U2[NLU Analysis<br/>Extract Intent + Context]
        U3[Semantic Matching<br/>Query Context Router]
        U4[Router Selection<br/>Pick Best Match]
        U5[Task Execution<br/>Via Selected Router]
        U6[Memory Bank Update<br/>8-Schema Atomic Write]
        U7[Response Generation<br/>Return to User]
    end

    subgraph SYS["System Entry"]
        A[global_rules.md<br/>Session Startup]
        B[architecture.mmd<br/>BEST Awareness]
        C[architecture.json<br/>Metadata]
    end

    subgraph HUB["Context Router Hub - Master Tunnel"]
        CR[context-router.json<br/>Semantic NLU<br/>Routes to 15 Routers]
    end

    subgraph GOV["Governance Routers - 4 Routers"]
        R1[constitutional.json<br/>CJ, PM, IAS, Shadow]
        R2[constitutional-index.json<br/>42 Articles Lazy Load]
        R3[constitutional-metadata.json<br/>Article Catalog]
        R4[governance.json<br/>Tri-Branch System]
    end

    subgraph OPS["Operations Routers - 4 Routers"]
        R5[core.json<br/>HALT-FIX-VALIDATE]
        R6[session.json<br/>State Management]
        R7[autonomy.json<br/>Execution Bands]
        R8[workflows.json<br/>8 Commands Router]
    end

    subgraph LEARN["Learning & Quality - 3 Routers"]
        R9[rl-feedback-loop.json<br/>PPO+GAE Scoring]
        R10[violations.json<br/>Penalty Enforcement]
        R11[skills.json<br/>Tech Stack Patterns]
    end

    subgraph INFRA["Infrastructure Routers - 4 Routers"]
        R12[memory-bank.json<br/>8-Schema Operations]
        R13[mcps.json<br/>6 Mandatory Tools]
        R14[parliamentary.json<br/>Consensus Voting]
    end

    subgraph CONST["Constitution - Supreme Law"]
        C1[42 Articles<br/>9 Parts]
        C2[Preamble<br/>Preliminary<br/>Rights]
        C3[Duties<br/>DPSP<br/>Parliament]
        C4[Executive<br/>Judiciary<br/>Bodies]
    end

    subgraph WF["Workflows - 8 Commands"]
        W1[auto-init<br/>bootstrap]
        W2[continue<br/>fix]
        W3[next<br/>research]
        W4[update<br/>validate]
    end

    subgraph MB["Memory Bank - 8 Runtime Files"]
        M1[activeContext.json<br/>Session State]
        M2[scratchpad.json<br/>Priority Queue]
        M3[kanban.json<br/>Task Workflow]
        M4[mistakes.json<br/>Error Patterns]
        M5[systemPatterns.json<br/>Reusable Solutions]
        M6[progress.json<br/>RL Central Ledger]
        M7[roadmap.json<br/>Strategic Planning]
        M8[memory.json<br/>Knowledge Graph]
    end

    subgraph SCH["Schemas - 10 Validation Files"]
        S1[activeContext.schema<br/>13,610 bytes]
        S2[progress.schema<br/>10,718 bytes]
        S3[kanban.schema<br/>scratchpad.schema]
        S4[memory.schema<br/>mistakes.schema]
        S5[systemPatterns.schema<br/>roadmap.schema]
        S6[schema-integrity-validator<br/>progress-rl-selection]
    end

    subgraph MCP["MCP Tools - 6 Mandatory"]
        T1[context7<br/>Official Docs]
        T2[fetch<br/>Web Content]
        T3[git<br/>Version Control]
        T4[sequential-thinking<br/>Structured Reasoning]
        T5[exa<br/>Code Search]
        T6[json-jq<br/>JSON Query]
    end

