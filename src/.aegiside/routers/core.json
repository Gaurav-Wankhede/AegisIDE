{
  "system_description": "AegisIDE Core Router - Essential Operations",
  "version": "2.0.0",
  "last_updated": "2025-10-18T21:11:07+05:30",
  
  "operational_loop": {
    "description": "Core execution sequence for every session/request",
    "steps": [
      {
        "step": 1,
        "name": "Session Awareness",
        "action": "Display constitutional rules",
        "query": "@mcp:json-jq query '.session_awareness' from 'routers/session.json'",
        "requirement": "FIRST action on new sessions"
      },
      {
        "step": 2,
        "name": "DeepThink", 
        "action": "Use @mcp:sequential-thinking (≥3 steps)",
        "query": "@mcp:json-jq query '.mcps.always_active[]' from 'routers/mcps.json'",
        "requirement": "EVERY request"
      },
      {
        "step": 3,
        "name": "Query Router",
        "action": "Get dynamic paths and rules", 
        "query": "@mcp:json-jq query '.system_paths' from 'routers/core.json'",
        "requirement": "NEVER use static paths"
      },
      {
        "step": 4,
        "name": "Execute",
        "action": "Use mandatory MCPs and CLI pipeline",
        "query": "@mcp:json-jq query '.mcps' from 'routers/mcps.json'",
        "requirement": "Complete MCP trail required"
      },
      {
        "step": 5,
        "name": "Update Memory",
        "action": "Atomically update all 8 schemas",
        "query": "@mcp:json-jq query '.memory_bank.schemas[]' from 'routers/memory-bank.json'",
        "requirement": "All 8 schemas or HALT"
      },
      {
        "step": 6,
        "name": "Auto-Continue",
        "action": "Process next task immediately",
        "query": "@mcp:json-jq query '.autonomy_rules' from 'routers/autonomy.json'",
        "requirement": "0-99% band, no permission"
      }
    ]
  },

  "system_paths": {
    "memory_bank": "{IDE}/.aegiside/memory-bank/",
    "schemas": "{IDE}/.aegiside/schemas/",
    "constitution": "{GLOBAL_MEMORY}/memories/",
    "workflows": "{IDE}/workflow/",
    "routers": "{IDE}/.aegiside/routers/"
  },

  "router_modules": {
    "core": "Essential operations and paths",
    "mcps": "MCP configurations and mandatory usage",
    "constitutional": "Constitutional roles and governance",
    "parliamentary": "Parliamentary system and voting",
    "session": "Session awareness and display",
    "memory-bank": "Memory bank and schema definitions",
    "autonomy": "Autonomy rules and execution bands",
    "violations": "Violations, penalties, and enforcement"
  },

  "loading_strategy": {
    "lazy_loading": "Load modules only when needed",
    "caching": "Cache frequently accessed modules per session",
    "specific_queries": "Use precise jq paths to avoid full file loads"
  }
}
